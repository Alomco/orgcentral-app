// Org starter preset pack linkage and override tracking

model OrganizationPresetSource {
  orgId              String   @id @db.Uuid
  packId             String   @db.Uuid
  packVersionId      String   @db.Uuid
  packVersionNumber  Int
  applyMode          String
  appliedAt          DateTime @default(now())
  appliedBy          String?  @db.Uuid
  overriddenFieldsJson Json?  @db.JsonB
  updatedAt          DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, packVersionId])
  @@map("organization_preset_sources")
  @@schema("hr")
}

model OrganizationPresetUpgradeSuggestion {
  id                String   @id @default(uuid()) @db.Uuid
  orgId             String   @db.Uuid
  fromPackVersionId String   @db.Uuid
  toPackVersionId   String   @db.Uuid
  diffJson          Json     @db.JsonB
  status            String   @default("PENDING")
  suggestedBy       String?  @db.Uuid
  suggestedAt       DateTime @default(now())
  resolvedBy        String?  @db.Uuid
  resolvedAt        DateTime?
  resolutionNote    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([orgId, toPackVersionId])
  @@map("organization_preset_upgrade_suggestions")
  @@schema("hr")
}

model OrganizationPresetOverride {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  moduleKey String
  fieldPath String
  valueJson Json     @db.JsonB
  reason    String?
  updatedBy String?  @db.Uuid
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleKey, fieldPath])
  @@index([orgId, moduleKey])
  @@map("organization_preset_overrides")
  @@schema("hr")
}